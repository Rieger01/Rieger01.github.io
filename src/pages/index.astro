---
import Band from '../components/Band.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductImage from '../components/ProductImage.astro';
import Excerpt from '../components/Excerpt.astro';
const pageTitle = "Lorem Ipsum";
const images = [
	{src: "/img/picture_placeholder.png", alt : "Purple mountains"},
	{src: "https://placecats.com/1500/1024", alt: "A cat staring at the viewer menacingly"},
	{src:"https://placehold.co/1440x1024", alt:"A placeholder with dimensions 1440 by 1024"}
];
const excerptTitles = [
	"Lorem Ipsum",
	"Etiam Accusam",
	"Donec Gravida",
	"Suspendisse Consectetur"
]
---
<BaseLayout pageTitle={pageTitle}>
	<section aria-labelledby="primary-heading">
		<h1 id="primary-heading" class="centered">{pageTitle}</h1>
		<div class="full__three_column gap__3_rem">
			{
				images.map(img => {
					return (
						<ProductImage src = {img.src} alt = {img.alt} />
					)
				})
			}
		</div>
	</section>
	<Band bandTitle = "Lorem Ipsum">
		Lorem ipsum dolor sit amet, consectetur adipiscing elit. Curabitur ut libero eu 
		justo mattis vulputate. Etiam accumsan sollicitudin turpis, a aliquam arcu. Donec 
		vel mi eu mi varius tincidunt id nec urna. Duis urna massa, hendrerit nec neque vel, 
		rutrum congue sem. Vivamus felis mi, ornare id dignissim ac, viverra sed quam. 
		In nec consectetur nulla. Aliquam cursus blandit magna, vel condimentum purus mattis 
		vitae. Sed nec tempus nibh, quis posuere massa. Etiam a placerat urna. Aliquam erat 
		volutpat. Donec gravida tortor arcu, sed fringilla arcu laoreet sed. Suspendisse 
		consectetur felis sem, ut interdum orci ornare non. Donec cursus massa non euismod 
		luctus.
	</Band>
	<section aria-labelledby="news-heading">
		<h2 id="news-heading" class="centered">News Ipsum</h2>
		<div class="full__four_column container text__column">
			{
				excerptTitles.map(title => (
					<Excerpt excerptTitle = {title}></Excerpt>
				))
			}
		</div>
	</section>
</BaseLayout>
